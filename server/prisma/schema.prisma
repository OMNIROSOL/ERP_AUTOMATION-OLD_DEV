generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["admin", "finance", "inventory", "master", "purchase", "sales"]
}

model Customer {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String         @unique
  name             String
  email            String?
  currency         String?        @default("USD")
  billingAddress   String?        @map("billing_address")
  status           String?        @default("Active")
  createdAt        DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  balance          Decimal?       @default(0) @db.Decimal(15, 2)
  credit_days      Int?           @default(30)
  credit_limit     Decimal?       @default(0) @db.Decimal(15, 2)
  delivery_address String?
  division         String?
  documentation    String?
  inactive         Boolean?       @default(false)
  sales_person     String?
  tpin             String?
  deliveryNotes    DeliveryNote[]
  salesInvoices    Invoice[]
  salesOrders      SalesOrder[]
  salesQuotes      SalesQuote[]

  @@map("customers")
  @@schema("master")
}

model Item {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemCode        String             @unique @map("item_code")
  itemName        String             @map("item_name")
  description     String?
  unitName        String?            @default("Pcs") @map("unit_name")
  valuationMethod String?            @default("FIFO") @map("valuation_method")
  isInactive      Boolean?           @default(false) @map("is_inactive")
  createdAt       DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  purchase_price  Decimal?           @default(0) @db.Decimal(15, 2)
  selling_price   Decimal?           @default(0) @db.Decimal(15, 2)
  categoryId      String?            @map("category_id") @db.Uuid
  category        ItemCategory?      @relation(fields: [categoryId], references: [id])
  stockLedger     StockLedger[]
  deliveryItems   DeliveryNoteItem[]
  invoiceItems    InvoiceItem[]
  quoteItems      QuoteItem[]
  procurementItems ProcurementOrderItem[]
  inventoryTransfers InventoryTransferItem[]
  grnItems        GoodsReceivedNoteItem[]
  technicalSpec   ItemTechnicalSpec?

  @@map("items")
  @@schema("master")
}

model ItemCategory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique
  description String?
  inactive    Boolean   @default(false)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  items       Item[]

  @@map("item_categories")
  @@schema("master")
}

model Invoice {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference  String        @unique
  issueDate  DateTime      @default(dbgenerated("CURRENT_DATE")) @map("issue_date") @db.Date
  dueDate    DateTime?     @map("due_date") @db.Date
  customerId String        @map("customer_id") @db.Uuid
  grandTotal Decimal?      @default(0) @map("grand_total") @db.Decimal(15, 2)
  balanceDue Decimal?      @default(0) @map("balance_due") @db.Decimal(15, 2)
  status     String?       @default("Unpaid")
  docOptions Json?         @default("{}") @map("doc_options")
  createdAt  DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  items      InvoiceItem[]
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("invoices")
  @@schema("sales")
}

model InvoiceItem {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String     @map("invoice_id") @db.Uuid
  itemId      String     @map("item_id") @db.Uuid
  qty         Decimal    @db.Decimal(12, 4)
  unitPrice   Decimal    @map("unit_price") @db.Decimal(15, 2)
  tax_code_id String?    @db.Uuid
  totalAmount Decimal    @map("total_amount") @db.Decimal(15, 2)
  invoice     Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item        Item       @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tax_codes   tax_codes? @relation(fields: [tax_code_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("invoice_items")
  @@schema("sales")
}

model SalesQuote {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference      String      @unique
  issueDate      DateTime    @default(dbgenerated("CURRENT_DATE")) @map("issue_date") @db.Date
  customerId     String      @map("customer_id") @db.Uuid
  description    String?
  currency       String?     @default("ZMW")
  amount         Decimal?    @default(0) @db.Decimal(15, 2)
  status         String?     @default("Active")
  billingAddress String?     @map("billing_address")
  expiryDays     Int?        @default(30) @map("expiry_days")
  docOptions     Json?       @default("{}") @map("doc_options")
  createdAt      DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  items          QuoteItem[]
  customer       Customer    @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("sales_quotes")
  @@schema("sales")
}

model QuoteItem {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId     String?     @map("quote_id") @db.Uuid
  orderId     String?     @map("order_id") @db.Uuid
  itemId      String      @map("item_id") @db.Uuid
  qty         Decimal     @db.Decimal(12, 4)
  unitPrice   Decimal     @map("unit_price") @db.Decimal(15, 2)
  totalAmount Decimal     @map("total_amount") @db.Decimal(15, 2)
  item        Item        @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order       SalesOrder? @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  quote       SalesQuote? @relation(fields: [quoteId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("quote_items")
  @@schema("sales")
}

model SalesOrder {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference      String      @unique
  orderDate      DateTime    @default(dbgenerated("CURRENT_DATE")) @map("order_date") @db.Date
  customerId     String      @map("customer_id") @db.Uuid
  description    String?
  currency       String?     @default("ZMW")
  amount         Decimal?    @default(0) @db.Decimal(15, 2)
  status         String?     @default("Pending")
  billingAddress String?     @map("billing_address")
  docOptions     Json?       @default("{}") @map("doc_options")
  createdAt      DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  items          QuoteItem[]
  customer       Customer    @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("sales_orders")
  @@schema("sales")
}

model DeliveryNote {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference         String             @unique
  deliveryDate      DateTime           @default(dbgenerated("CURRENT_DATE")) @map("delivery_date") @db.Date
  customerId        String             @map("customer_id") @db.Uuid
  description       String?
  status            String?            @default("Issued")
  inventoryLocation String?            @map("inventory_location")
  timestamp         DateTime?          @default(now()) @map("timestamp") @db.Timestamptz(6)
  items             DeliveryNoteItem[]
  customer          Customer           @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("delivery_notes")
  @@schema("sales")
}

model DeliveryNoteItem {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliveryNoteId String       @map("delivery_note_id") @db.Uuid
  itemId         String       @map("item_id") @db.Uuid
  qty            Decimal      @db.Decimal(12, 4)
  deliveryNote   DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item           Item         @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("delivery_note_items")
  @@schema("sales")
}

model Receipt {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference         String    @unique
  date              DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  paidByContact     String    @map("paid_by_contact")
  receivedInAccount String    @map("received_in_account")
  description       String?
  amount            Decimal   @db.Decimal(15, 2)
  currency          String?   @default("ZMW")
  status            String?   @default("Completed")
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("receipts")
  @@schema("sales")
}

model Location {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @unique
  code        String?       @unique
  description String?
  inactive    Boolean       @default(false)
  createdAt   DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  stockLedger StockLedger[]

  @@map("location")
  @@schema("inventory")
}

model InventoryWriteOff {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date          DateTime  @db.Date
  reference     String    @unique
  inventoryItem String    @map("inventory_item")
  qty           Decimal   @db.Decimal(12, 4)
  amount        Decimal   @db.Decimal(15, 2)
  account       String?
  description   String?
  status        String    @default("Draft")
  division      String?
  allocation    String?
  taxCode       String?   @map("tax_code")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("inventory_write_offs")
  @@schema("inventory")
}

model InventoryUnitCost {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date            DateTime  @db.Date
  itemId          String    @map("item_id")
  itemName        String    @map("item_name")
  unitCost        Decimal   @map("unit_cost") @db.Decimal(15, 4)
  minSellingPrice Decimal   @map("min_selling_price") @db.Decimal(15, 4)
  division        String
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("inventory_unit_costs")
  @@schema("inventory")
}

model InventoryTransfer {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference    String                  @unique
  date         DateTime                @default(now()) @db.Date
  fromLocation String                  @map("from_location")
  toLocation   String                  @map("to_location")
  description  String?
  status       String                  @default("Draft")
  createdAt    DateTime?               @default(now()) @map("created_at") @db.Timestamptz(6)
  items        InventoryTransferItem[]

  @@map("inventory_transfers")
  @@schema("inventory")
}

model InventoryTransferItem {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transferId String            @map("transfer_id") @db.Uuid
  itemId     String            @map("item_id") @db.Uuid
  qty        Decimal           @db.Decimal(15, 4)
  transfer   InventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item       Item              @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("inventory_transfer_items")
  @@schema("inventory")
}

model StockLedger {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId           String    @map("item_id") @db.Uuid
  locationId       String    @map("location_id") @db.Uuid
  qtyChange        Decimal   @map("qty_change") @db.Decimal(12, 4)
  transactionType  String    @map("transaction_type")
  sourceDocumentId String?   @map("source_document_id") @db.Uuid
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  item             Item      @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  location         Location  @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([itemId, locationId], map: "idx_stock_master")
  @@map("stock_ledger")
  @@schema("inventory")
}

model ChartOfAccount {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String        @unique
  name             String
  accountType      String        @map("account_type")
  isPaymentAccount Boolean?      @default(false) @map("is_payment_account")
  ledgerEntries    LedgerEntry[]

  @@map("chart_of_accounts")
  @@schema("finance")
}

model LedgerEntry {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId          String         @map("account_id") @db.Uuid
  transactionDate    DateTime?      @default(dbgenerated("CURRENT_DATE")) @map("transaction_date") @db.Date
  debit              Decimal?       @default(0) @db.Decimal(15, 2)
  credit             Decimal?       @default(0) @db.Decimal(15, 2)
  transactionType    String?        @map("transaction_type")
  source_document_id String?        @db.Uuid
  account            ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([accountId], map: "idx_ledger_account")
  @@map("ledger_entries")
  @@schema("finance")
}

model permissions {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id    String   @db.Uuid
  screen_id  String
  can_view   Boolean? @default(false)
  can_add    Boolean? @default(false)
  can_edit   Boolean? @default(false)
  can_delete Boolean? @default(false)
  roles      roles    @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([role_id, screen_id])
  @@schema("admin")
}

model profiles {
  id         String    @id @db.Uuid
  email      String    @unique
  full_name  String?
  role_id    String?   @db.Uuid
  is_active  Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  roles      roles?    @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("admin")
}

model roles {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @unique
  description String?
  permissions permissions[]
  profiles    profiles[]

  @@schema("admin")
}

model suppliers {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String     @unique
  name            String
  email           String?
  currency        String?    @default("USD")
  status          String?    @default("Active")
  billing_address String?
  division        String?
  balance         Decimal?   @default(0) @db.Decimal(15, 2)
  inactive        Boolean?   @default(false)
  created_at      DateTime?  @default(now()) @db.Timestamptz(6)
  invoices          invoices[]
  leadTime          SupplierLeadTime?
  procurementOrders ProcurementOrder[]

  @@schema("master")
}

model item_units {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @unique
  code       String    @unique
  is_active  Boolean   @default(true)
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("master")
}


model tax_codes {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @unique
  rate          Decimal       @default(0) @db.Decimal(5, 2)
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  invoice_items InvoiceItem[]

  @@schema("master")
}

model invoices {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference   String
  supplier_id String    @db.Uuid
  grand_total Decimal?  @default(0) @db.Decimal(15, 2)
  status      String?   @default("Unpaid")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  suppliers   suppliers @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("purchase")
}

model divisions {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("master")
}

model SupplierLeadTime {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId        String    @unique @map("supplier_id") @db.Uuid
  processingDays    Int       @default(0) @map("processing_days")
  productionDays    Int       @default(0) @map("production_days")
  shippingDays      Int       @default(0) @map("shipping_days")
  roadTransportDays Int       @default(0) @map("road_transport_days")
  supplier          suppliers @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("supplier_lead_times")
  @@schema("purchase")
}

model GoodsReceivedNote {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receivedDate      DateTime?               @default(dbgenerated("CURRENT_DATE")) @map("received_date") @db.Date
  reference         String                  @unique
  purchaseOrder     String?                 @map("purchase_order")
  supplier          String
  inventoryLocation String?                 @map("inventory_location")
  description       String?
  status            String?                 @default("Pending")
  items             GoodsReceivedNoteItem[]
  timestamp         DateTime?               @default(now()) @map("timestamp") @db.Timestamptz(6)

  @@map("goods_received_notes")
  @@schema("purchase")
}

model GoodsReceivedNoteItem {
  id     String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  grnId  String            @map("grn_id") @db.Uuid
  itemId String            @map("item_id") @db.Uuid
  qty    Decimal           @db.Decimal(15, 4)
  grn    GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item   Item              @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("goods_received_note_items")
  @@schema("purchase")
}

model ProcurementOrder {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference       String                 @unique
  supplierId      String                 @map("supplier_id") @db.Uuid
  status          String                 @default("Draft")
  orderDate       DateTime               @default(now()) @map("order_date")
  projectedEta    DateTime?              @map("projected_eta")
  totalLandedCost Decimal?               @default(0) @map("total_landed_cost") @db.Decimal(15, 2)
  currency        String?                @default("USD")
  description     String?
  supplier        suppliers              @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items           ProcurementOrderItem[]
  expenses        LandedCostAllocation[]

  @@map("procurement_orders")
  @@schema("purchase")
}

model ProcurementOrderItem {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String           @map("order_id") @db.Uuid
  itemId        String           @map("item_id") @db.Uuid
  qty           Decimal          @db.Decimal(15, 4)
  unitPrice     Decimal          @map("unit_price") @db.Decimal(15, 2)
  totalAmount   Decimal          @map("total_amount") @db.Decimal(15, 2)
  landedCost    Decimal?         @map("landed_cost") @db.Decimal(15, 2)
  order         ProcurementOrder @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item          Item             @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("procurement_order_items")
  @@schema("purchase")
}

model LandedCostAllocation {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String           @map("order_id") @db.Uuid
  expenseName  String           @map("expense_name")
  amount       Decimal          @db.Decimal(15, 2)
  allocationId String?          @map("allocation_id") // ID for the specific expense type
  order        ProcurementOrder @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("landed_cost_allocations")
  @@schema("purchase")
}

model ItemTechnicalSpec {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId      String   @unique @map("item_id") @db.Uuid
  specText    String?  @map("spec_text")
  photoUrl    String?  @map("photo_url")
  attachments Json?    @default("[]")
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("item_technical_specs")
  @@schema("master")
}
